# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).

# --- Database (async driver) ---
DATABASE_URL=postgresql+asyncpg://vulnscan:vulnscan@localhost:5432/vulnscan

# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Auth (JWT) ---
# MUST be a strong, unique value in production (>=32 bytes).
VULNSCAN_JWT_SECRET=dev-insecure-secret-change-me-in-production
VULNSCAN_ACCESS_TTL_MIN=15
VULNSCAN_REFRESH_TTL_DAYS=7

# --- Webhooks (outbound report delivery + inbound callbacks) ---
VULNSCAN_WEBHOOK_SECRET=dev-insecure-webhook-secret

# --- AI engine (Anthropic Claude) ---
ANTHROPIC_API_KEY=
# Override the analysis model if needed (defaults to Claude Sonnet).
# VULNSCAN_CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Payments (Stripe) ---
# Secret key (sk_...) and webhook signing secret (whsec_...). Read by the
# payment gateway at call time; never persisted (CLAUDE.md §7.3).
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Debug ---
# Set to 1 to echo all SQL statements (noisy; dev only).
VULNSCAN_SQL_ECHO=0
